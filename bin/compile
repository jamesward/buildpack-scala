#!/usr/bin/env bash
# Heroku classic buildpack: compile
# Usage: bin/compile <BUILD_DIR> <CACHE_DIR> [ENV_DIR]
#
# Strategy:
#   1. Point sbt/coursier/ivy caches at CACHE_DIR so deps persist between builds.
#   2. Run `./sbt stage` to stage the app (sbt-native-packager's task).
#   3. Run a second `./sbt 'show Universal / stagingDirectory'` and parse the
#      printed path. Two cold starts is fine — the path needs to come from
#      sbt itself (`target/out/jvm/scala-X/proj/universal/stage` varies by
#      Scala version and project name) and `show <key>` is core sbt and is
#      reliable in every environment.
#   4. Replace BUILD_DIR contents with the staging dir contents, preserving
#      the user-supplied Procfile and any slug-side contributions made by
#      buildpacks that ran before this one (e.g. heroku/jvm's .jdk/).
#
# Multi-project builds: set the SBT_PROJECT config var to the subproject ID
# whose `Universal / stage` should drive the slug (e.g.
# `heroku config:set SBT_PROJECT=server`). When unset, the buildpack uses the
# root project's `stage`.
#
# Result: the slug root *is* the staged universal directory. Procfile entries
# must therefore be relative to the staging root (e.g. `web: bin/<exec>`).

set -euo pipefail
shopt -s dotglob nullglob

BUILD_DIR=${1:-}
CACHE_DIR=${2:-}
ENV_DIR=${3:-}

status() { echo "-----> $*"; }
fail()   { echo " !     $*" >&2; exit 1; }

# Strip sbt 2.0 supershell / ANSI control sequences and CRs. sbt 2.0 emits an
# `ESC[0J` (erase-below) after task output even with -no-colors, and on a cold
# build can render the value line without a trailing newline — gluing it to the
# following `[success]` line. Both are normalized away here.
strip_ansi() { sed 's/\x1b\[[0-9;?]*[A-Za-z]//g' | tr -d '\r'; }

[[ -n $BUILD_DIR ]] || fail "usage: bin/compile <BUILD_DIR> <CACHE_DIR> [ENV_DIR]"
[[ -d $BUILD_DIR ]] || fail "BUILD_DIR not found: $BUILD_DIR"
[[ -n $CACHE_DIR ]] || fail "CACHE_DIR not provided"
mkdir -p "$CACHE_DIR"

# Convert to absolute paths so we can chdir freely.
BUILD_DIR=$(cd "$BUILD_DIR" && pwd)
CACHE_DIR=$(cd "$CACHE_DIR" && pwd)

# ---- export user config vars from ENV_DIR -----------------------------------
# Heroku passes a directory of files; each filename is a config var name and
# its content is the value. We expose them so sbt sees them at build time.
if [[ -n $ENV_DIR && -d $ENV_DIR ]]; then
  for f in "$ENV_DIR"/*; do
    [[ -f $f ]] || continue
    name=$(basename "$f")
    # skip vars that would let users hijack the build
    case "$name" in
      PATH|GIT_DIR|LD_*|JAVA_TOOL_OPTIONS) continue ;;
    esac
    export "$name=$(cat "$f")"
  done
fi

# ---- cleanup registry -------------------------------------------------------
declare -a CLEANUP_PATHS=()
cleanup() {
  local rc=$?
  for p in "${CLEANUP_PATHS[@]}"; do
    rm -rf -- "$p" 2>/dev/null || true
  done
  exit $rc
}
trap cleanup EXIT

# ---- caching ----------------------------------------------------------------
# Persist coursier (sbt 2 default) + ivy + sbt boot across builds.
# shellcheck source=bin/util/sbt-env.sh
. "$(dirname "$0")/util/sbt-env.sh"
sbt_env_configure "$CACHE_DIR"

# ---- run sbt stage and capture the staging dir ------------------------------
cd "$BUILD_DIR"
[[ -f ./sbt ]] || fail "no ./sbt wrapper in $BUILD_DIR"
chmod +x ./sbt

# Multi-project support: if SBT_PROJECT is set (typically via
# `heroku config:set SBT_PROJECT=<id>`), scope every sbt command to that
# subproject. When unset, sbt uses the current (root) project.
SBT_PROJECT=${SBT_PROJECT:-}
if [[ -n $SBT_PROJECT ]]; then
  stage_cmd="$SBT_PROJECT/stage"
  show_key="$SBT_PROJECT / Universal / stagingDirectory"
  status "Targeting subproject: $SBT_PROJECT"
else
  stage_cmd="stage"
  show_key="Universal / stagingDirectory"
fi

status "Running ./sbt $stage_cmd"
./sbt "$stage_cmd"

# Ask sbt for the staging directory path. With sbt 2.0 we disable the
# supershell so task output is plain, newline-terminated log lines instead of
# cursor-addressed redraws. We still defensively strip any residual escapes.
#
# Extraction is deliberately tolerant: rather than requiring a pristine
# `[info] <path>` line (which sbt 2.0's supershell can mangle by gluing the
# value to the next `[success]` line), we pull the first absolute path that
# ends in `universal/stage`. A non-match yields an empty string (never a
# pipeline failure), so the explicit check below — not `set -e` — owns the
# error path and always prints the captured output for triage.
status "Asking sbt for $show_key"
set +e
SBT_OUT=$(./sbt -no-colors -Dsbt.supershell=false "show $show_key" 2>&1)
SBT_RC=$?
set -e
if [[ $SBT_RC -ne 0 ]]; then
  echo "----- ./sbt show output -----" >&2
  echo "$SBT_OUT" >&2
  echo "-----------------------------" >&2
  fail "./sbt 'show $show_key' failed (exit $SBT_RC)"
fi

STAGING_DIR=$(printf '%s\n' "$SBT_OUT" | strip_ansi | grep -oE '/[^[:space:]]*/universal/stage' | tail -1 || true)

# Filesystem fallback: after `<proj>/stage` runs, the directory exists on disk
# regardless of how sbt logged its path. This makes the buildpack resilient to
# future sbt output-format changes.
if [[ -z $STAGING_DIR || ! -d $STAGING_DIR ]]; then
  STAGING_DIR=$(find "$BUILD_DIR/target" -type d -path "*${SBT_PROJECT:+/$SBT_PROJECT}/universal/stage" 2>/dev/null | sort | tail -1 || true)
fi

if [[ -z $STAGING_DIR || ! -d $STAGING_DIR ]]; then
  echo "----- ./sbt show output -----" >&2
  echo "$SBT_OUT" >&2
  echo "-----------------------------" >&2
  fail "could not determine the staging directory for '$show_key'"
fi

status "Staging directory: ${STAGING_DIR#$BUILD_DIR/}"

# ---- locate the Procfile that applies to this slug --------------------------
# The slug root *is* the staging dir. For a multi-project build that staging
# dir belongs to the subproject named by SBT_PROJECT, so the Procfile that
# should ship is the one in that subproject's directory — not the repo root.
# The sbt project ID need not match its directory name, so ask sbt for the
# subproject's baseDirectory rather than guessing `$BUILD_DIR/$SBT_PROJECT`.
# (Single-project builds use the repo-root Procfile, so we skip this extra
# cold boot for them.)
PROJECT_BASE=""
if [[ -n $SBT_PROJECT ]]; then
  base_key="$SBT_PROJECT / baseDirectory"
  status "Asking sbt for $base_key"
  set +e
  BASE_OUT=$(./sbt -no-colors -Dsbt.supershell=false "show $base_key" 2>&1)
  BASE_RC=$?
  set -e
  if [[ $BASE_RC -ne 0 ]]; then
    echo "----- ./sbt show output -----" >&2
    echo "$BASE_OUT" >&2
    echo "-----------------------------" >&2
    fail "./sbt 'show $base_key' failed (exit $BASE_RC)"
  fi
  # The base dir is an absolute path on its own `[info]` line. Tolerate escapes
  # and value/[success] gluing the same way as the staging-dir lookup.
  PROJECT_BASE=$(printf '%s\n' "$BASE_OUT" | strip_ansi \
    | sed -nE 's/.*[[:space:]](\/[^[:space:]]+)([[:space:]].*)?$/\1/p' \
    | grep -vE '/universal/stage$' \
    | tail -1 || true)
  # Fallback: a subproject whose directory name matches its id.
  if [[ -z $PROJECT_BASE || ! -d $PROJECT_BASE ]] && [[ -d "$BUILD_DIR/$SBT_PROJECT" ]]; then
    PROJECT_BASE="$BUILD_DIR/$SBT_PROJECT"
  fi
  if [[ -z $PROJECT_BASE || ! -d $PROJECT_BASE ]]; then
    echo "----- ./sbt show output -----" >&2
    echo "$BASE_OUT" >&2
    echo "-----------------------------" >&2
    fail "could not determine $base_key from sbt output"
  fi
  status "Subproject base directory: ${PROJECT_BASE#$BUILD_DIR/}"
fi

# Prefer the subproject's Procfile (multi-project), fall back to the repo-root
# Procfile (single-project, or a multi-project build that keeps its Procfile
# at the root).
PROCFILE_SRC=""
if [[ -n $PROJECT_BASE && -f "$PROJECT_BASE/Procfile" ]]; then
  PROCFILE_SRC="$PROJECT_BASE/Procfile"
elif [[ -f "$BUILD_DIR/Procfile" ]]; then
  PROCFILE_SRC="$BUILD_DIR/Procfile"
fi

# ---- assemble the slug ------------------------------------------------------
# Copy staged contents into a temp dir, then preserve user-controlled runtime
# files AND slug contributions made by earlier buildpacks (heroku/jvm bundles
# a JDK at .jdk/ and a PATH/JAVA_HOME script at .profile.d/jdk.sh — both must
# survive the build-dir rewrite or `java` won't be on PATH at runtime).
# Then atomically replace the build dir contents.
SLUG_TMP=$(mktemp -d)
CLEANUP_PATHS+=("$SLUG_TMP")

cp -a "$STAGING_DIR"/. "$SLUG_TMP"/

# Names at $BUILD_DIR root that should survive the rewrite. Add to this list
# if you chain another buildpack that contributes a slug-side directory.
# NOTE: the Procfile is handled separately below — its source location depends
# on whether this is a multi-project build (see PROCFILE_SRC above).
PRESERVE=(
  .profile.d   # PATH/env scripts contributed by buildpacks (e.g. heroku/jvm)
  .jdk         # JDK installed by heroku/jvm
  .heroku      # generic Heroku slug-side metadata
)

for name in "${PRESERVE[@]}"; do
  [[ -e "$BUILD_DIR/$name" ]] || continue
  rm -rf -- "${SLUG_TMP:?}/$name"
  cp -a "$BUILD_DIR/$name" "$SLUG_TMP/$name"
done

# Ship the applicable Procfile (subproject's for multi-project builds, else
# the repo-root one) at the slug root, where Heroku expects it.
if [[ -n $PROCFILE_SRC ]]; then
  rm -rf -- "$SLUG_TMP/Procfile"
  cp -a "$PROCFILE_SRC" "$SLUG_TMP/Procfile"
  status "Using Procfile from ${PROCFILE_SRC#$BUILD_DIR/}"
fi

status "Replacing build dir with slug contents"
cd /
find "$BUILD_DIR" -mindepth 1 -maxdepth 1 -exec rm -rf -- {} +
cp -a "$SLUG_TMP"/. "$BUILD_DIR"/

status "Slug root contents: $(cd "$BUILD_DIR" && ls)"
